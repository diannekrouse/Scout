# Path to the substrate root containing index/ and sources/.
# Defaults to ./sample-dossier (the bundled Welcome workspace) when unset
# or commented out.
DOSSIER_ROOT=./sample-dossier

# Optional: comma-separated list of workspace IDs to expose.
# When unset, every workspace in workspaces.json is visible.
# Useful for demos, hand-offs, and scoped screen-shares.
# Example: ALLOWED_WORKSPACES=welcome,research
ALLOWED_WORKSPACES=
